# Gemini API - 절대 실제 키를 넣지 마세요. .env에만 설정하세요.
GOOGLE_API_KEY=your_google_api_key_here
# gemini-2.5-pro (추천), gemini-3.1-pro-preview (최신)
GEMINI_MODEL_TEXT=gemini-2.5-pro
GEMINI_MODEL_IMAGE=gemini-2.5-pro

# App
FEEDBACK_MIN_ROUNDS=5
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_FILE_SIZE_MB=10
JOB_TIMEOUT_MINUTES=15
FILE_RETENTION_HOURS=24
# 로컬: http://localhost:5173 | 배포: https://doligo.pages.dev (쉼표로 구분)
CORS_ORIGINS=http://localhost:5173,https://doligo.pages.dev
LOG_LEVEL=info
GEMINI_RETRY_COUNT=3
